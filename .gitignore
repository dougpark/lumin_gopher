# --- LUMIN GOPHER .gitignore ---

# Bun/Node Dependencies
node_modules/
bun.lockb

# Environment / Secrets
# (Never commit your actual API keys!)
.env
.env.local
.env.*.local

# Docker
.docker/
# If you decide to store persistent DB data in a local folder
data/
db/

# OS / IDE
.DS_Store
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Debug/Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# Build Outputs (if you ever use bun build)
dist/
out/

# Local Research / Scratchpad
temp/
scratch/